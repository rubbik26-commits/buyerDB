# ── Backend / worker environment ──────────────────────────────────────────
# Copy to .env for local dev. In production these live in the host's secret store
# (Render/Railway/Fly/VPS for API + Python worker/cron services) — NOT in git.

# Database (Supabase session pooler in production). The Python worker needs write
# access to sbi_deals/sbi_properties/sbi_entities/sbi_source_runs and ledgers.
DATABASE_URL=postgresql://skyline:skyline_dev@localhost/skyline

# Backend connection-pool ceiling. FastAPI serves sync endpoints from a ~40-
# thread pool and getconn() raises immediately when empty, so this must cover
# realistic concurrency (default 40).
DB_POOL_MAX=40

# NYC Open Data (Socrata). Not strictly secret, but registering an app token
# lifts you out of the shared anonymous throttle pool. data.cityofnewyork.us
SOCRATA_APP_TOKEN=

# Traded fallback transport ONLY. curl_cffi (free) is primary on the Python
# worker; ScraperAPI is the env-gated fallback if traded.co hardens.
SCRAPERAPI_KEY=
TRADED_REQUEST_DELAY=3

# Worker queue/cron settings
WORKER_POLL_SECONDS=30
WORKER_MAX_CLAIMS_PER_TICK=1
ROLLING_BATCH=400

# Optional Crexi refresh through Apify. If missing, crexi_refresh is skipped
# honestly and does not pretend to have ingested anything.
APIFY_TOKEN=
APIFY_CREXI_ACTOR=
CREXI_WAIT_SECONDS=120
CREXI_MAX_ITEMS=1000

# ── AI providers (all optional; the router uses whatever is present) ─────────
# Free lanes: Groq (primary tool lane), Gemini (Flash only; DO NOT send uploaded
# contact data here — free tier may train on prompts), OpenRouter, Cloudflare.
# Paid quality lane: Anthropic (no free tier) and/or OpenAI.
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional model overrides (sane defaults baked in)
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.5-flash
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o-mini

# Router chains. Fast/tool lane tries these in order; quality lane first, then
# degrades to the fast lane so an answer is never silently dropped.
AI_PROVIDER_ORDER=groq,gemini,openrouter,cloudflare
AI_QUALITY_PROVIDER=anthropic,openai

# Entity-resolution fuzzy threshold (starting point; tune against real uploads)
ENTITY_TRGM_THRESHOLD=0.55

# CORS: comma-separated frontend origins allowed to call the API
FRONTEND_URL=http://localhost:5173

# Failure alerting (worker/cron host if supported)
ALERT_WEBHOOK_URL=
