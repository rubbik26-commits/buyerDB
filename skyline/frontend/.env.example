# Frontend environment — NOTHING SECRET EVER GOES HERE.
# The bundle is public; provider keys and DB URLs live only on the backend.

# Where the app reads data from. Two modes, detected by the URL:
#   backend mode: a FastAPI host, e.g. http://localhost:8000
#   RPC mode:     the Supabase REST gateway, e.g. https://<ref>.supabase.co/rest/v1
VITE_API_URL=http://localhost:8000

# RPC mode only: the Supabase ANON (publishable) key — the PUBLIC key that RLS
# is designed around. NEVER the service_role key. If unset, the bundled
# fallback key for the production project is used.
#VITE_SUPABASE_ANON_KEY=
